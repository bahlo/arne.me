{% extends "_includes/default.njk" %}

{% block content %}
{% for entry in collections.entries | reverse %}
<article>
  <a href="{{ entry.url | url }}"><h1>{{ entry.data.title }}</h1></a>
  <i><time datetime="{{ entry.data.date | htmlDateString }}">{{ entry.data.date | readableDate }}</time></i><br>
  {% if entry.data.cover %}<img width="360" src="{{ entry.data.cover }}" alt="Cover">{% endif %}
  {% if entry.data.photo %}<img width="360" src="{{ entry.data.photo }}" alt="{{ entry.data.altText }}">{% endif %}
  {{ entry.templateContent | safe }}
</article>
{% endfor %}
{% endblock %}
