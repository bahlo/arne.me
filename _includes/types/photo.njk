<article class="photo">
  <a href={{ entry.url }}><h1>{{ entry.data.title }}</h1></a>
  <i><time datetime="{{ entry.data.date | htmlDateString }}">{{ entry.data.date | readableDate }}</time></i>
  <br>
  <img src={{ entry.data.photo }} alt="{{ altText }}">
  {{ entry.templateContent | safe }}
</article>
