{% extends "_includes/default.njk" %}

{% block content %}
<p>As you can probably see, this site is under construction.</p>

<h1>Blogposts</h1>
<ul>
  {% for post in collections.posts | reverse %}
    <li>
      <a href="{{ post.url | url }}">{{ post.data.title }}</a>
    </li>
  {% endfor %}
</ul>

<h1>Links</h1>
<ul>
  {% for link in collections.links | reverse %}
  <li>
    <a href="{{ link.data.url | url }}">{{ link.data.title }}</a>
  </li>
  {% endfor %}
</ul>

<h1>Books</h1>
<ul>
  {% for book in collections.books | reverse %}
  <li>
    <a href="{{ book.url | url }}">{{ book.data.title }} – {{ book.data.author }}</a>
  </li>
  {% endfor %}
</ul>

<h1>Photos</h1>
<ul>
  {% for photo in collections.photos | reverse %}
  <li>
    <a href="{{ photo.url | url }}">{{ photo.data.title }}</a>
    <br>
    <img width="360" src="{{ photo.data.photo }}" alt="{{ photo.data.altText }}">
  </li>
  {% endfor %}
</ul>
{% endblock %}
